{
  "models": { "http_timeout_s": 2400 },
  "features": {
    "chat": {
      "enabled": true,
      "chat_summarise": {
        "threshold_chars": 5000,
        "threshold_messages": 6,
        "keep_recent_exchanges": 3
      },
      "models": {
        "chat":                { "role": "t1_secondary" },
        "chat_summarise":      { "role": "exp_rwkv_r", "temperature": 0.1, "max_tokens": 500, "max_input_chars": 16000, "frequency_penalty": 0.2 },
        "chat_memory_extract": { "role": "t3_tool",    "temperature": 0.2, "max_tokens": 1500, "max_input_chars": 16000 }
      }
    },
    "code": {
      "enabled": true,
      "models": {
        "code": { "role": "t2_coder" }
      }
    },
    "code_v2": {
      "enabled": true,
      "glossary_top_n": 12,
      "models": {
        "code_review":       { "role": "t2_coder", "temperature": 0.2, "max_tokens": 1500, "max_input_chars": 12000 },
        "file_summary":      { "role": "t3_tool",  "temperature": 0.2, "max_tokens": 220,  "max_input_chars": 8000 },
        "readme_maintain":   { "role": "t3_tool",  "temperature": 0.2, "max_tokens": 800,  "max_input_chars": 8000 },
        "faq_maintain":      { "role": "t3_tool",  "temperature": 0.2, "max_tokens": 800,  "max_input_chars": 6000 },
        "smart_paste":       { "role": "t3_tool",  "temperature": 0.0, "max_tokens": 200,  "max_input_chars": 4000 },
        "playbook_generate": { "role": "t2_coder", "temperature": 0.2, "max_tokens": 1200, "max_input_chars": 4000 },
        "spec_regen":        { "role": "t2_coder", "temperature": 0.2, "max_tokens": 2000, "max_input_chars": 8000 }
      }
    },
    "web_search": {
      "enabled": true,
      "standard_query_count_min": 2,
      "standard_query_count_max": 3,
      "basic_max_urls": 8,
      "standard_max_urls": 8,
      "basic_query_cap": 5,
      "standard_query_cap": 3,
      "searxng_per_query": 10,
      "priority_urls": 2,
      "priority_extract_chars": 2500,
      "supplementary_extract_chars": 1200,
      "rerank_when_candidates_over": 15,
      "rerank_max": 8,
      "batch_target": 5,
      "max_summary_chars": 1500,
      "relevance_keyword_threshold": 0.16,
      "relevance_min_abs_hits": 2,
      "relevance_min_keep": 4,
      "models": {
        "web_search_query_generator": { "role": "t3_tool",    "temperature": 0.2, "max_tokens": 600, "max_input_chars": 4000 },
        "web_search_summarise":       { "role": "exp_rwkv_r", "temperature": 0.2, "max_tokens": 300, "max_input_chars": 3000, "frequency_penalty": 0.2 },
        "web_search_summarise_batch": { "role": "exp_rwkv_r", "temperature": 0.2, "max_tokens": 400, "max_input_chars": 8000, "frequency_penalty": 0.2 }
      }
    },
    "rag_lookup": true,
    "tools_framework": {
      "enabled": true,
      "models": {
        "tool_planner": { "role": "t3_tool", "temperature": 0.1, "max_tokens": 200, "max_input_chars": 1000 }
      }
    },
    "search_extraction": {
      "enabled": true,
      "models": {
        "search_extraction": { "role": "exp_rwkv_r", "temperature": 0.2, "max_tokens": 350, "max_input_chars": 4000, "frequency_penalty": 0.2 },
        "content_quality":   { "role": "t3_tool",    "temperature": 0.0, "max_tokens": 6,   "max_input_chars": 1500 }
      }
    },
    "intent_classifier": {
      "enabled": true,
      "models": {
        "intent_classifier": { "role": "t3_tool", "temperature": 0.1, "max_tokens": 300, "max_input_chars": 2000 }
      }
    },
    "url_scraper": {
      "enabled": true,
      "max_urls_per_turn": 3,
      "max_links_per_url": 30,
      "scrape_timeout_s": 60
    },
    "models": {
      "http_timeout_s": 3600
    },
    "scraper": {
      "enabled": true,
      "dispatch_interval_seconds": 60,
      "summariser_model": "scrape_summariser",
      "_comment_models": "scrape_summariser runs on every scraped page. scrape_classifier is used inline by the discover agent on search results pre-approval.",
      "models": {
        "scrape_summariser": { "role": "exp_rwkv_r", "temperature": 0.2, "max_tokens": 500, "max_input_chars": 12000, "frequency_penalty": 0.2 },
        "scrape_classifier": { "role": "t3_tool",    "temperature": 0.1, "max_tokens": 200, "max_input_chars": 8000 }
      }
    },
    "teaching": {
      "output_dir": "/tmp/jeffgpt_teaching_output",
      "enabled": true,
      "models": {
        "teaching_curriculum":  { "role": "t1_secondary", "temperature": 0.2, "max_tokens": 4000,  "max_input_chars": 12000 },
        "teaching_lesson":      { "role": "t1_secondary", "temperature": 0.3, "max_tokens": 12000, "max_input_chars": 32000 },
        "teaching_lesson_meta": { "role": "t3_tool",      "temperature": 0.2, "max_tokens": 3000,  "max_input_chars": 16000 },
        "teaching_revision":    { "role": "t1_secondary", "temperature": 0.3, "max_tokens": 12000, "max_input_chars": 32000 },
        "teaching_check":       { "role": "t3_tool",      "temperature": 0.2, "max_tokens": 2000,  "max_input_chars": 12000 }
      }
    },
    "research": {
      "output_dir": "/tmp/jeffgpt_research_output",
      "planner_enabled": true,
      "agent_enabled": true,
      "max_queries": 8,
      "planner_retry_attempts": 2,
      "planner_retry_backoff_s": 4,
      "planner_timeout_s": 240,
      "planner_fallback_enabled": true,
      "web_search_per_query_timeout_s": 120,
      "basic_skip_doc_type_inference": true,
      "section_timeout_s": 1800,
      "doc_type_timeout_s": 300,
      "reviewer_timeout_s": 2400,
      "stale_plan_hours": 24,
      "search_extraction_model": "research_search_extraction",
      "models": {
        "research_planner":           { "role": "t3_tool",     "temperature": 0.2, "max_tokens": 4000,  "max_input_chars": 12000 },
        "research_doc_type":          { "role": "t3_tool",     "temperature": 0.1, "max_tokens": 60,    "max_input_chars": 2000 },
        "research_section_writer":    { "role": "t1_secondary","temperature": 0.3, "max_tokens": 4000,  "max_input_chars": 32000 },
        "research_reviewer":          { "role": "t1_secondary","temperature": 0.2, "max_tokens": 12000, "max_input_chars": 64000 },
        "research_agent":             { "role": "t1_secondary","temperature": 0.3, "max_tokens": 20000, "max_input_chars": 30000 },
        "research_search_extraction": { "role": "exp_rwkv_r",  "temperature": 0.2, "max_tokens": 500,   "max_input_chars": 12000, "frequency_penalty": 0.2 }
      }
    },
    "graph_extract": {
      "enabled": true,
      "models": {
        "relationships": { "role": "t1_secondary", "temperature": 0.1, "max_tokens": 800, "max_input_chars": 8000, "frequency_penalty": 0.3 }
      }
    },
    "daily_digest": {
      "enabled": true,
      "cron_hour": 7,
      "cron_minute": 0,
      "window_hours": 24,
      "scan_limit": 500,
      "model": "daily_digest",
      "models": {
        "daily_digest": { "role": "exp_rwkv_r", "temperature": 0.2, "max_tokens": 800, "max_input_chars": 12000, "frequency_penalty": 0.2 }
      }
    },
    "seed_feedback": {
      "enabled": true,
      "run_interval_hours": 6,
      "min_relevance": "medium",
      "results_per_query": 6,
      "max_hits_per_query": 2,
      "recent_dedup_days": 7,
      "recent_dedup_scan_limit": 500,
      "sparse_concepts_limit": 10,
      "sparse_max_degree": 3,
      "domain_stats_window_days": 14,
      "domain_stats_message_scan_limit": 1000,
      "domain_stats_target_scan_limit": 5000,
      "weak_rag_window_days": 7,
      "weak_rag_scan_limit": 300,
      "weak_rag_max_queries_per_run": 10
    },
    "corpus_maintenance": {
      "enabled": true,
      "run_interval_hours": 12,
      "scan_limit": 3000,
      "stale_refresh_enabled": true,
      "stale_days": 30,
      "stale_cite_window_days": 14,
      "stale_cite_scan_limit": 500,
      "max_refresh_per_run": 25,
      "dup_detect_enabled": true,
      "dup_threshold": 0.85,
      "dup_shingle_k": 5,
      "dup_max_per_domain": 200,
      "dup_purge_chroma": true
    },
    "harvest": {
      "enabled": true,
      "extractor_timeout_s": 600,
      "default_rate_limit_per_host_s": 1.0,
      "default_respect_robots": true,
      "default_max_pages": 100,
      "default_max_depth": 2,
      "default_timeout_total_s": 3600,
      "fetch_timeout_s": 30,
      "max_body_bytes": 5242880,
      "user_agent": "mst-harness/1.0 (+contact)",
      "yield_every_n_urls": 10,
      "yield_pause_s": 2,
      "skip_graph_extract_on_persist": true,
      "_comment": "yield_pause_s lets chat / higher-priority jobs preempt during long crawls. skip_graph_extract_on_persist=true avoids queueing one graph_extract per harvested URL (200-URL bulk would otherwise queue 200 LLM jobs).",
      "host_policies": {}
    },
    "pathfinder": {
      "enabled": true,
      "dispatch_interval_seconds": 2400,
      "same_host_only": true,
      "max_links_per_seed": 100
    },
    "discover_agent": {
      "enabled": true,
      "run_interval_minutes": 20,
      "sample_collection": "discovery",
      "sample_chunks": 12,
      "sample_max_chars_per_chunk": 400,
      "queries_per_run": 6,
      "results_per_query": 8,
      "max_suggestions_per_run": 20,
      "min_relevance": "medium",
      "existing_scan_limit": 5000,
      "query_model": "tool_planner",
      "classify_model": "scrape_classifier"
    },
    "home": {
      "enabled": true,
      "digest_preface_chars": 2000,
      "default_chat_model": "chat",
      "timezone": "Australia/Sydney",
      "daily_brief_schedule": {
        "monday_morning":  "30 6 * * 1",
        "midweek_morning": "30 6 * * 2-4",
        "friday_pm":       "30 16 * * 5",
        "weekday_midday":  "0 14 * * 1-5",
        "weekend":         "30 9 * * 0,6"
      },
      "anchored_asks_lead_minutes": 5,
      "research_seeder_cron": "0 22 * * *",
      "email": { "enabled": false },
      "calendar": { "enabled": false },
      "graph": { "enabled": true }
    },
    "daily_brief": {
      "enabled": true,
      "max_body_chars": 3500
    },
    "anchored_asks": {
      "enabled": true,
      "max_per_run": 3
    },
    "research_seeder": {
      "enabled": true,
      "max_topics_per_night": 2
    },
    "pa": {
      "enabled": true,
      "proactive_min_gap_hours": 4.0,
      "warmth_half_life_hours": 48.0,
      "models": {
        "pa_extractor":              { "role": "exp_rwkv_r",   "temperature": 0.2, "max_tokens": 500,  "max_input_chars": 6000,  "frequency_penalty": 0.2 },
        "pa_topic_research":         { "role": "t1_secondary", "temperature": 0.3, "max_tokens": 260,  "max_input_chars": 4000 },
        "pa_assistant_commitments":  { "role": "exp_rwkv_r",   "temperature": 0.1, "max_tokens": 200,  "max_input_chars": 4000,  "frequency_penalty": 0.2 },
        "daily_brief":               { "role": "t1_secondary", "temperature": 0.4, "max_tokens": 3500, "max_input_chars": 16000 }
      }
    },
    "surfacing": {
      "enabled": false,
      "email_to": ""
    },
    "graph_maintenance": {
      "enabled": true,
      "entity_resolution_interval_hours": 24,
      "maintenance_interval_hours": 168,
      "entity_scan_limit": 500,
      "max_merges_per_run": 25,
      "max_pairs_per_label": 20,
      "alias_similarity_threshold": 0.72,
      "alias_confidence_floor": 0.75,
      "decay_factor": 0.9,
      "drop_below_weight": 0.2,
      "co_occurrence_min": 2,
      "co_occurrence_limit": 40,
      "models": {
        "graph_alias_judge": { "role": "t3_tool", "temperature": 0.0, "max_tokens": 150, "max_input_chars": 2000 }
      }
    },
    "insights": {
      "enabled": true,
      "tick_minutes": 10,
      "chat_idle_hours": 2,
      "fallback_hours": 12,
      "auto_research": false,
      "models": {
        "insight_topic_picker": { "role": "t3_tool",    "temperature": 0.3, "max_tokens": 500,  "max_input_chars": 6000 },
        "insight_synthesis":    { "role": "t1_primary", "temperature": 0.3, "max_tokens": 3500, "max_input_chars": 28000 },
        "insight_ack":          { "role": "exp_rwkv_r", "temperature": 0.4, "max_tokens": 120,  "max_input_chars": 1500 }
      }
    },
    "project": {
      "autonomy_mode": "proposal-only",
      "max_tasks_per_hour": 4,
      "max_queued_proposals": 10,
      "max_daily_tokens": 100000,
      "consecutive_failure_backoff": true,
      "models": {
        "project_agent": { "role": "t2_coder" },
        "project_po":    { "role": "t1_primary" }
      }
    },
    "tool_queue": {
      "background_chat_idle_seconds": 1800,
      "strict_background_gating": true,
      "allow_force_bypass_idle": false,
      "chat_turn_stale_seconds": 21600,
      "default_max_attempts": 3,
      "default_retry_backoff_seconds": 5,
      "queue_jumpers": {
        "research_planner": false,
        "research_agent": false,
        "summarise_page": false,
        "graph_extract": false,
        "scrape_page": false,
        "pathfinder_extract": false,
        "extract_relationships": false,
        "discover_agent_run": false,
        "daily_digest": false,
        "seed_feedback": false,
        "corpus_maintenance": false,
        "insight_produce": false,
        "graph_resolve_entities": false,
        "graph_maintenance": false,
        "pa_topic_research": false
      },
      "job_type_max_attempts": {
        "summarise_page": 3,
        "scrape_page": 2,
        "pathfinder_extract": 2,
        "extract_relationships": 2,
        "discover_agent_run": 2,
        "research_planner": 2,
        "research_agent": 2,
        "daily_digest": 1,
        "seed_feedback": 1,
        "corpus_maintenance": 1,
        "harvest_run": 1,
        "harvest_finalise": 1
      },
      "huey": {
        "consumer_workers": 16,
        "task_retries": 2,
        "task_retry_delay_seconds": 5
      }
    }
  }
}
